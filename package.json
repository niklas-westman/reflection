{
  "name": "reflection",
  "version": "0.0.0",
  "description": "CLI for evidence-backed rendered UI validation.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "bin": {
    "reflection": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "keywords": [
    "ui-validation",
    "playwright",
    "visual-regression",
    "design-systems",
    "developer-tools"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "reflection": "pnpm build && node dist/cli.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "jiti": "^2.7.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/pngjs": "^6.0.5",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.12.1"
}
